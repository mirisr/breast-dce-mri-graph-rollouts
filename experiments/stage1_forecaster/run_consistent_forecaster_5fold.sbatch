#!/bin/bash
#SBATCH --job-name=cg-fc-5fold
#SBATCH --output=experiments/stage1_forecaster/logs/cg5fold-%A_%a.out
#SBATCH --error=experiments/stage1_forecaster/logs/cg5fold-%A_%a.err
#SBATCH --time=04:00:00
#SBATCH --partition=gpul40q
#SBATCH --gpus=1
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=32G
#SBATCH --array=0-4

# 5-fold cross-validation of the consistent-graph forecaster on the full
# ISPY2+ACRIN cohort (all patients with 4 visits, graphs_consistent built).
#
# Each array task trains one fold (val fold = $SLURM_ARRAY_TASK_ID).
# Uses the stratified folds from datasets/ispy2/folds.parquet (same splits
# as the Stage-1 S1.10 baseline for apples-to-apples comparison).
#
# Prerequisites:
#   - datasets/ispy2/graphs_consistent/<pid>.pt built for all patients
#   - reports/all_patients_4visit.txt generated by make_full_patient_list.py
#
# Submit (after graph building completes):
#   sbatch --dependency=afterok:<BUILD_JOB_ID> \
#          experiments/stage1_forecaster/run_consistent_forecaster_5fold.sbatch

set -euo pipefail
cd "$HOME/3DGCNN"
mkdir -p experiments/stage1_forecaster/logs

export LD_LIBRARY_PATH="$HOME/miniforge3/envs/3dgcnn/lib:${LD_LIBRARY_PATH:-}"
export OMP_NUM_THREADS=2
PY="$HOME/miniforge3/envs/3dgcnn/bin/python"

FOLD="${SLURM_ARRAY_TASK_ID}"
OUT_DIR="runs/consistent_forecaster_5fold/fold${FOLD}"
mkdir -p "$OUT_DIR"

echo "[cg-fc-5fold] fold=$FOLD out=$OUT_DIR start=$(date -Iseconds)"
srun "$PY" experiments/stage1_forecaster/train_consistent_forecaster.py \
    --graphs-root  datasets/ispy2/graphs_consistent \
    --patient-list reports/all_patients_4visit.txt \
    --folds-parquet datasets/ispy2/folds.parquet \
    --fold         "$FOLD" \
    --out-dir      "$OUT_DIR" \
    --pretrained   experiments/stage1_forecaster/runs/b1_posweight2x/fold${FOLD}/best.pt \
    --hidden       64 \
    --num-layers   2 \
    --epochs       400 \
    --lr           3e-4 \
    --patience     60 \
    --freeze-backbone-epochs 30
echo "[cg-fc-5fold] fold=$FOLD end=$(date -Iseconds)"
